# MaxMind GeoLite2 license key for the maxmind-sync workflow.
#
# Install:
#   mkdir -p ~/.config/cron-services
#   cp deploy/maxmind.env.example ~/.config/cron-services/maxmind.env
#   chmod 600 ~/.config/cron-services/maxmind.env
#   # then edit the file and set your real key
#
# Get a key at: https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_KEY=your_license_key_here
